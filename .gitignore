.env
.env.*
!.env.example

# Reference-only snapshot of the live WordPress site (not source code).
site-mirror/

# Local browser/session data and secrets.
cookies.txt
*.cookie
*.cookies
auth.json
*.key
*.pem
*.p12
*.pfx

# Runtime/private store data.
admin/private/*
!admin/private/.htaccess

# Ephemeral certificate validation files.
.well-known/acme-challenge/*
.well-known/pki-validation/*

backups/
*.sql
*.sql.gz
*.zip
*.tar
*.tar.gz

node_modules/
__pycache__/
*.pyc
.pytest_cache/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db
